# --- CULTURE ---
msgid "Hungarian Culture"
msgstr "Magyar kultúra"

msgid "Folk dances and traditional clothing"
msgstr "Néptánc és hagyományos ruházat"

msgid "Handmade crafts and embroidery"
msgstr "Kézműves alkotások és hímzés"

msgid "Famous composers like Franz Liszt and Béla Bartók"
msgstr "Liszt Ferenc és Bartók Béla"

# --- FOOD ---
msgid "Hungarian Food"
msgstr "Magyar ételek"

msgid "Hungarian cuisine is known for its rich flavors and use of paprika."
msgstr "A magyar konyha híres a paprikáról."

msgid "Goulash – a traditional meat stew"
msgstr "Gulyás"

msgid "Chicken Paprikash – creamy paprika dish"
msgstr "Paprikás csirke"

msgid "Lángos – fried flatbread"
msgstr "Lángos"

msgid "Dobos Torte – layered cake with caramel"
msgstr "Dobos torta"

# --- HISTORY ---
msgid "Hungary History"
msgstr "Magyar történelem"

msgid "Hungary has a long and rich history, dating back over a thousand years. It includes the formation of the Hungarian state and important events like the 1848 Revolution."
msgstr "Magyarország történelme több mint ezer évre nyúlik vissza."

