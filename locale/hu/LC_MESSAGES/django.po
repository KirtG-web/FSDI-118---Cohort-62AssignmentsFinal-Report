msgstr "Magyarország híres nevezetességei"

msgid "Hungarian Parliament Building in Budapest"
msgstr "Országház"

msgid "Buda Castle"
msgstr "Budai vár"

msgid "Chain Bridge"
msgstr "Lánchíd"

# --- LANGUAGE ---
msgid "Hungarian Language"
msgstr "Magyar nyelv"

msgid "The official language of Hungary is Hungarian (Magyar). It belongs to the Finno-Ugric language family."
msgstr "A magyar nyelv hivatalos nyelv."

msgid "Very different from most European languages"
msgstr "Nagyon különbözik az európai nyelvektől"

msgid "Uses unique grammar rules"
msgstr "Egyedi nyelvtan"

msgid "Includes accented characters"
msgstr "Ékezetes karaktereket tartalmaz"

# --- HOLIDAYS ---
msgid "Holidays & Traditions"
msgstr "Ünnepek és hagyományok"

msgid "Hungary has many rich and meaningful holidays that reflect its culture, history, and traditions."
msgstr "Magyarország gazdag ünnepi hagyományokkal rendelkezik."

msgid "Christmas"
msgstr "Karácsony"

msgid "Easter"
msgstr "Húsvét"

msgid "St. Stephen’s Day"
msgstr "Szent István napja"

msgid "Celebrated with unique traditions like \"watering\" and colorful folk customs."
msgstr "Locsolkodás és népi hagyományok jellemzik."

